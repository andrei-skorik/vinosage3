OPENROUTER_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=
ADMIN_PASSWORD=
KB_SOURCE_URL=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
EMBEDDING_MODEL=openai/text-embedding-3-small
RATE_LIMIT_PER_MIN=10
DAILY_COST_CAP_EUR=1.00

# Durable conversation state (SPEC step 9). Optional — app degrades to
# in-memory history when absent. Use the Supabase Session pooler URI.
DATABASE_URL=

# LangSmith observability (optional — app runs identically if left blank)
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=vinosage
# Required for EU-region LangSmith accounts; leave blank for the default (US) region.
LANGSMITH_ENDPOINT=

# Optional STT model override (default: whisper-large-v3-turbo)
TRANSCRIBE_MODEL=
